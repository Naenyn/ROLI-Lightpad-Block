            <variable name="bank2FaderCC" displayName="Fader CC" type="int" min="0" max="127" value="0" initStart="120" tooltip="MIDI CC when Bank 2 is selected."/>
        </vector>
        <vector count="4" group="stdBank3Faders" wantsGetFunctions="true" wantsSetFunctions="true">
            <variable name="bank3FaderCC" displayName="Fader CC" type="int" min="0" max="127" value="0" initStart="124" tooltip="MIDI CC when Bank 3 is selected."/>
