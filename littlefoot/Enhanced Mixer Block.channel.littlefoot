        <group name="stdBankColors" displayName="Additional bank fader colors" />
        <group name="stdBank1Faders" displayName="Bank 1 Fader *" count="4" />
        <group name="stdBank2Faders" displayName="Bank 2 Fader *" count="4" />
        <group name="stdBank3Faders" displayName="Bank 3 Fader *" count="4" />
	</groups>
	<variables>
        <variable name="midiChannel" displayName="MIDI Channel" type="int" min="1" max="16" value="1" displayMode="stepper" tooltip="The MIDI channel that values are sent on" />
        <variable name="bottomDetentRange" displayName="Standard fader zero detent" type="int" min="0" max="15" value="7" tooltip="Standard faders: values 0–N snap to 0 at bottom. 0 = disabled."/>
        <variable name="centerDetentRange" displayName="Bipolar fader center detent" type="int" min="0" max="15" value="5" tooltip="Fader 2 (pan) only: values within ±N of 64 snap to center. 0 = disabled."/>
        <variable name="mainFader1CC" displayName="Fader 1 (modwheel) CC" group="mainFaders" type="int" min="0" max="127" value="1" tooltip="Standard fader; default CC 1."/>
        <variable name="stripMainFader1MinColor" displayName="Fader 1 (modwheel) min color" group="mainFaders" type="colour" value="0xff5082f1" tooltip="Modwheel fader: gradient low."/>
        <variable name="stripMainFader1MaxColor" displayName="Fader 1 (modwheel) max color" group="mainFaders" type="colour" value="0xff50f182" tooltip="Modwheel fader: gradient high."/>
        <variable name="mainFader2CC" displayName="Fader 2 (pan) CC" group="mainFaders" type="int" min="0" max="127" value="112" tooltip="Bidirectional pan-style; default CC 112."/>
        <variable name="stripMainBiNegColor" displayName="Fader 2 (pan) negative color" group="mainFaders" type="colour" value="0xff5082f1" tooltip="Pan fader: 64 toward 0."/>
        <variable name="stripMainBiPosColor" displayName="Fader 2 (pan) positive color" group="mainFaders" type="colour" value="0xfff18250" tooltip="Pan fader: 64 toward 127."/>
        <variable name="mainFader3CC" displayName="Fader 3 (volume) CC" group="mainFaders" type="int" min="0" max="127" value="113" tooltip="Standard fader; default CC 113."/>
        <variable name="stripMainFader3MinColor" displayName="Fader 3 (volume) min color" group="mainFaders" type="colour" value="0xff5082f1" tooltip="Volume fader: gradient low."/>
        <variable name="stripMainFader3MaxColor" displayName="Fader 3 (volume) max color" group="mainFaders" type="colour" value="0xff50f182" tooltip="Volume fader: gradient high."/>
        <variable name="stdBank1MinColor" displayName="Bank 1 min color" group="stdBankColors" type="colour" value="0xff5082f1" tooltip="Gradient low for Bank 1 faders (columns when on that bank)."/>
        <variable name="stdBank1MaxColor" displayName="Bank 1 max color" group="stdBankColors" type="colour" value="0xff50f182" tooltip="Gradient high for Bank 1."/>
        <variable name="stdBank2MinColor" displayName="Bank 2 min color" group="stdBankColors" type="colour" value="0xff5082f1" tooltip="Gradient low for Bank 2."/>
        <variable name="stdBank2MaxColor" displayName="Bank 2 max color" group="stdBankColors" type="colour" value="0xff50f182" tooltip="Gradient high for Bank 2."/>
        <variable name="stdBank3MinColor" displayName="Bank 3 min color" group="stdBankColors" type="colour" value="0xff5082f1" tooltip="Gradient low for Bank 3."/>
        <variable name="stdBank3MaxColor" displayName="Bank 3 max color" group="stdBankColors" type="colour" value="0xff50f182" tooltip="Gradient high for Bank 3."/>
        <variable name="stripSoloButtonCC" displayName="Solo Button CC" group="stripButtons" type="int" min="0" max="127" value="106" tooltip="MIDI CC for solo (toggle)."/>
        <variable name="stripMuteButtonCC" displayName="Mute Button CC" group="stripButtons" type="int" min="0" max="127" value="107" tooltip="MIDI CC for mute (toggle)."/>
        <variable name="button1CC" displayName="MIDI CC" group="btnStop" type="int" min="0" max="127" value="102" tooltip="MIDI CC for stop. Fixed Gate on the pad."/>
        <variable name="button2CC" displayName="MIDI CC" group="btnPlay" type="int" min="0" max="127" value="103" tooltip="MIDI CC for play. Fixed Toggle."/>
        <variable name="button3CC" displayName="MIDI CC" group="btnRecord" type="int" min="0" max="127" value="104" tooltip="MIDI CC for record. Fixed Toggle."/>
        <variable name="button4CC" displayName="MIDI CC" group="btnMetro" type="int" min="0" max="127" value="105" tooltip="Metronome: gated latch. While off, hold sends CC 127; release sends nothing and latches on. While on, tap sends CC 0 and turns off."/>
        <vector count="4" group="stdBank1Faders" wantsGetFunctions="true" wantsSetFunctions="true">
            <variable name="bank1FaderCC" displayName="Fader CC" type="int" min="0" max="127" value="0" initStart="116" tooltip="MIDI CC when this bank is selected on the block."/>
