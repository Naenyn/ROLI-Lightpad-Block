/*
<metadata description="Channel-strip mixer: primary bank has three main faders plus solo/mute; three additional banks of four faders each." details="Four transport buttons on row 1: stop (column 1) is Gate; play and record are Toggle; metronome is gated latch (hold sends 127, release latches on; tap again sends 0). CCs configurable. Primary bank: Fader 1 (modwheel) and Fader 3 (volume) standard, Fader 2 (pan) bidirectional; colors and CCs in Dashboard. Solo Button and Mute Button CCs (toggle). Additional banks 1–3: four faders each (Bank N Fader *), with per-bank gradient colors. Mode switches bank."
          target="Lightpad" 
          tags="MIDI;Controller;Mixing;" canEmbedModes="false">
	<groups>
        <group name="btnStop" displayName="Button 1 (stop)" />
        <group name="btnPlay" displayName="Button 2 (play)" />
        <group name="btnRecord" displayName="Button 3 (record)" />
